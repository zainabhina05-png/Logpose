# Snowflake Account
SNOWFLAKE_ACCOUNT=            # e.g. xy12345.us-east-1
SNOWFLAKE_USERNAME=
SNOWFLAKE_PRIVATE_KEY=        # full PEM contents, newlines escaped as \n
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=   # only if the key was generated with a passphrase
SNOWFLAKE_DATABASE=logpose_db
SNOWFLAKE_SCHEMA=app
SNOWFLAKE_WAREHOUSE=logpose_wh
SNOWFLAKE_ROLE=logpose_app_role

# Auth
JWT_SECRET=                   # openssl rand -hex 32
